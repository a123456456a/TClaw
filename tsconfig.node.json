{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2020",
    "noEmit": false,
    "outDir": "dist-electron"
  },
  "include": ["electron/**/*.ts", "vite.config.mts"]
}