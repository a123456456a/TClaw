{
  "name": "tclaw",
  "version": "0.1.0",
  "description": "OpenClaw Desktop Controller",
  "packageManager": "pnpm@10.15.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.2",
    "chokidar": "^3.6.0",
    "element-plus": "^2.7.6",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.31",
    "vue-router": "^4.3.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.10",
    "@types/ws": "^8.5.11",
    "@vitejs/plugin-vue": "^5.0.5",
    "concurrently": "^8.2.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.26",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.tclaw.app",
    "productName": "TClaw",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}