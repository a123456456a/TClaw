{
  "name": "tclaw",
  "version": "0.1.0",
  "description": "OpenClaw Desktop Controller",
  "author": "TClaw",
  "packageManager": "pnpm@10.15.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false vue-tsc --noEmit && vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64",
    "build:linux": "vue-tsc --noEmit && vite build && electron-builder --linux --x64",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "typecheck": "vue-tsc --noEmit",
    "icons:build": "node scripts/build-icons.cjs"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "chokidar": "^3.6.0",
    "element-plus": "^2.7.6",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.5",
    "pinia": "^2.1.7",
    "vue": "^3.4.31",
    "vue-router": "^4.3.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.0.5",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.2.2",
    "to-ico": "^1.1.5",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.26",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.tclaw.app",
    "productName": "TClaw",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "package.json",
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "sign": null,
      "signDlls": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "${productName}-${version}-setup-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TClaw"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "synopsis": "OpenClaw Desktop Controller",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "icon": "build/icon.png",
      "maintainer": "TClaw"
    }
  }
}